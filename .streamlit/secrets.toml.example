# ▼ このファイルを secrets.toml という名前でコピーして、値を入れてください。
#   （secrets.toml は秘密情報なので Git にはアップされません）
#
# ・クラウド(Streamlit Community Cloud)では、この内容を
#   アプリ設定の「Secrets」画面に貼り付けます。
# ・PC(ローカル)で同じクラウドDBを使いたいときは、このファイルを
#   .streamlit/secrets.toml として置きます。

# SupabaseのデータベースURL（Project Settings → Database → Connection string → URI）
DATABASE_URL = "postgresql://postgres:【DBパスワード】@db.【プロジェクトID】.supabase.co:5432/postgres"

# アプリのログインパスワード（共有1つ・自由に決めてください）
APP_PASSWORD = "【ログインパスワード】"

# ヤマトB2クラウド自動取得用（PC側のsecrets.tomlにのみ設定。クラウドには不要）
# YAMATO_CUSTOMER_CODE = "【お客様コード（数字）】"
# YAMATO_PASSWORD = "【B2ログインパスワード】"
